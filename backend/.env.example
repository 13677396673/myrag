# =============================================================================
# MyRAG 环境变量模板
# 将本文件复制为 .env 并根据需要修改值：
#   cp .env.example .env
#
# 优先级：环境变量 > .env > config.yaml > Settings 类默认值
# 环境变量名与字段名完全一致（如 LLM_BACKEND=openai）
# =============================================================================

# ── 应用基础配置 ──
APP_NAME=myrag
APP_VERSION=0.1.0
APP_DEBUG=true

# ── 服务配置 ──
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_CORS_ORIGINS=["http://localhost:5173"]

# ── 数据库配置 ──
# 开发环境使用 SQLite；生产环境推荐 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./data/myrag.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/myrag
DATABASE_ECHO=false

# ── JWT 配置 ──
# ！！！生产环境务必修改 JWT_SECRET_KEY ！！！
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 文件存储配置 ──
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/uploads
STORAGE_MAX_FILE_SIZE=52428800
# S3 / MinIO 配置（STORAGE_BACKEND=s3 或 minio 时需配置）
# STORAGE_S3_ENDPOINT=http://localhost:9000
# STORAGE_S3_ACCESS_KEY=minioadmin
# STORAGE_S3_SECRET_KEY=minioadmin
# STORAGE_S3_BUCKET=myrag-uploads

# ── 任务队列配置 ──
TASK_QUEUE_BACKEND=huey
# TASK_QUEUE_REDIS_URL=redis://localhost:6379/0

# ── LLM 配置 ──
LLM_BACKEND=deepseek

# DeepSeek（当前默认后端）
# ！！！如使用 DeepSeek，请设置 DEEPSEEK_API_KEY ！！！
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI（备选后端，需将 LLM_BACKEND 改为 openai）
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama（本地部署，需将 LLM_BACKEND 改为 ollama）
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b

# ── Embedding 配置 ──
EMBEDDING_BACKEND=bge-small
EMBEDDING_BGE_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_BGE_DEVICE=cpu
EMBEDDING_OPENAI_MODEL=text-embedding-3-small
EMBEDDING_DEEPSEEK_MODEL=deepseek-embedding

# ── 向量数据库配置 ──
VECTOR_STORE_BACKEND=chromadb
VECTOR_STORE_CHROMA_PATH=./data/chromadb
VECTOR_STORE_MILVUS_HOST=localhost
VECTOR_STORE_MILVUS_PORT=19530
# VECTOR_STORE_PGVECTOR_CONNECTION=postgresql://user:pass@localhost:5432/myrag

# ── 检索配置 ──
RETRIEVAL_TOP_K=5
RETRIEVAL_SIMILARITY_THRESHOLD=0.0
RETRIEVAL_MODE=vector
RETRIEVAL_RERANK_ENABLED=false

# ── 切片配置 ──
SPLITTER_TYPE=fixed
SPLITTER_CHUNK_SIZE=512
SPLITTER_CHUNK_OVERLAP=64

# ── LLM 生成参数 ──
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

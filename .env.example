# ═══════════════════════════════════════════════════════════
# MyRAG 环境变量配置
# ═══════════════════════════════════════════════════════════
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#
# 优先级：环境变量 > .env 文件 > 代码默认值
# 所有配置项均可通过环境变量覆盖

# ═══ 必需 ═════════════════════════════════════════════════

# LLM API 密钥（至少配置一个后端）
# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# 若使用 OpenAI 作为 LLM 或 Embedding 后端：
# OPENAI_API_KEY=sk-your-openai-api-key


# ═══ 应用基础 ═════════════════════════════════════════════

# 调试模式（开发时开启，生产关闭）
# APP_DEBUG=true

# CORS 允许的前端域名（数组格式，逗号分隔）
# SERVER_CORS_ORIGINS=["http://localhost:5173","http://localhost"]


# ═══ 数据库 ═══════════════════════════════════════════════

# 数据库连接串（默认 SQLite，生产推荐 PostgreSQL）
# SQLite:   sqlite+aiosqlite:///./data/myrag.db
# PostgreSQL: postgresql+asyncpg://user:pass@host:5432/myrag
# DATABASE_URL=sqlite+aiosqlite:///./data/myrag.db

# SQLAlchemy 日志（调试时开启）
# DATABASE_ECHO=false


# ═══ JWT ══════════════════════════════════════════════════

# JWT 签名密钥（生产环境必须修改为随机字符串）
# JWT_SECRET_KEY=change-me-in-production

# Token 过期时间（分钟，默认 1440 = 24 小时）
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440


# ═══ 文件存储 ═════════════════════════════════════════════

# 存储后端：local | s3 | minio
# STORAGE_BACKEND=local

# 本地存储路径（仅 local 模式）
# STORAGE_LOCAL_PATH=./data/uploads

# 上传文件大小上限（字节，默认 50MB）
# STORAGE_MAX_FILE_SIZE=52428800

# S3/MinIO 配置（STORAGE_BACKEND=s3 或 minio 时需设置）
# STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
# STORAGE_S3_ACCESS_KEY=your-access-key
# STORAGE_S3_SECRET_KEY=your-secret-key
# STORAGE_S3_BUCKET=myrag-uploads


# ═══ 任务队列 ═════════════════════════════════════════════

# 任务队列后端：huey | celery | arq
# TASK_QUEUE_BACKEND=huey

# Redis 连接 URL（celery/arq 模式必需）
# TASK_QUEUE_REDIS_URL=redis://localhost:6379/0


# ═══ LLM ══════════════════════════════════════════════════

# LLM 后端：deepseek | openai | ollama
# LLM_BACKEND=deepseek

# DeepSeek 配置
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI 配置
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama 配置（本地）
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b

# 生成参数
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=2048


# ═══ Embedding ════════════════════════════════════════════

# Embedding 后端：bge-small | openai | deepseek
# EMBEDDING_BACKEND=bge-small

# BGE 本地模型（首次运行自动下载）
# EMBEDDING_BGE_MODEL=BAAI/bge-small-zh-v1.5
# EMBEDDING_BGE_DEVICE=cpu  # cpu | cuda

# OpenAI Embedding
# EMBEDDING_OPENAI_MODEL=text-embedding-3-small

# DeepSeek Embedding
# EMBEDDING_DEEPSEEK_MODEL=deepseek-embedding


# ═══ 向量数据库 ══════════════════════════════════════════

# 向量存储后端：chromadb | faiss | milvus | pgvector
# VECTOR_STORE_BACKEND=chromadb

# ChromaDB 持久化路径
# VECTOR_STORE_CHROMA_PATH=./data/chromadb

# Milvus 配置
# VECTOR_STORE_MILVUS_HOST=localhost
# VECTOR_STORE_MILVUS_PORT=19530

# PGVector 连接串
# VECTOR_STORE_PGVECTOR_CONNECTION=postgresql://user:pass@host:5432/myrag


# ═══ 检索配置 ════════════════════════════════════════════

# 检索返回的文档数量（1~100）
# RETRIEVAL_TOP_K=5

# 相似度阈值（0.0~1.0，低于此阈值的结果将被过滤）
# RETRIEVAL_SIMILARITY_THRESHOLD=0.0

# 检索模式：vector | hybrid
# RETRIEVAL_MODE=vector

# 启用重排序
# RETRIEVAL_RERANK_ENABLED=false


# ═══ 切片配置 ════════════════════════════════════════════

# 切片策略：fixed | markdown | semantic
# SPLITTER_TYPE=fixed

# 切片大小（64~8192）
# SPLITTER_CHUNK_SIZE=512

# 切片重叠（0~256）
# SPLITTER_CHUNK_OVERLAP=64
